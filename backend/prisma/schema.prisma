generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id              String       @id @default(uuid())
  code            String       @unique @db.Char(6)
  hostId          String
  phase           Phase        @default(lobby)
  theme           String?
  drawTimeSeconds Int          @default(90)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  drawings        Drawing[]
  rankings        Ranking[]
  roomPlayers     RoomPlayer[]

  @@index([code])
  @@index([hostId])
}

model Player {
  id               String          @id
  fullName         String
  imageUrl         String
  clerkId          String          @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  drawings         Drawing[]
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  sentRequests     FriendRequest[] @relation("SentRequests")
  friendOf         PlayerFriend[]  @relation("FriendOf")
  friends          PlayerFriend[]  @relation("PlayerFriends")
  rankings         Ranking[]
  roomPlayers      RoomPlayer[]

  @@index([clerkId])
}

model RoomPlayer {
  id       String   @id @default(uuid())
  roomId   String
  playerId String
  isHost   Boolean  @default(false)
  joinedAt DateTime @default(now())
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, playerId])
  @@index([roomId])
  @@index([playerId])
}

model PlayerFriend {
  id        String   @id @default(uuid())
  playerId  String
  friendId  String
  createdAt DateTime @default(now())
  friend    Player   @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  player    Player   @relation("PlayerFriends", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, friendId])
  @@index([playerId])
  @@index([friendId])
}

model FriendRequest {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  receiver   Player        @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     Player        @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([senderId])
}

model Drawing {
  id          String    @id @default(uuid())
  roomId      String
  playerId    String
  playerName  String
  strokes     Json      @default("[]")
  submittedAt DateTime  @default(now())
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  rankings    Ranking[]

  @@index([roomId])
  @@index([playerId])
}

model Ranking {
  id        String   @id @default(uuid())
  roomId    String
  voterId   String
  drawingId String
  rank      Int
  createdAt DateTime @default(now())
  drawing   Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  voter     Player   @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([voterId, drawingId])
  @@index([roomId])
  @@index([drawingId])
}

enum RequestStatus {
  pending
  accepted
  rejected
}

enum Phase {
  lobby
  theme_vote
  drawing
  voting
  results
}
